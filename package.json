{
  "name": "browser-game-playset",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A browser game playset with tower defense, 3D cabin survival, voxel building, and orbital defense prototypes.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 8094",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 8094",
    "verify": "node scripts/verify.mjs",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "phaser": "^3.90.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/three": "^0.185.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=20"
  }
}
